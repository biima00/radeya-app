# Database Connection String for Prisma
# PostgreSQL format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DATABASE_NAME]?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/radeya_dev?schema=public"

# NextAuth Configuration (JWT Secret)
NEXTAUTH_SECRET="your-32-character-random-jwt-secret-key"

# Gemini AI Vet API Key
GEMINI_API_KEY=""

# Midtrans Configuration (Sandbox / Dev)
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY="SB-Mid-client-xxxxxx"
MIDTRANS_SERVER_KEY="SB-Mid-server-xxxxxx"
MIDTRANS_IS_PRODUCTION="false"
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION="false"
